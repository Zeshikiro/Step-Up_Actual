# --- Unity Default Build & Temporary Output Folders ---
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[MemoryCaptures]/
/[VeeVee]/

# --- Visual Studio & IDE Cache Directories ---
.vs/
.gradle/
/[As]mdef[Cc]ache/

# --- Autogenerated Solution & Project Compilation Files ---
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb

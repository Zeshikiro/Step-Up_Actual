# --- Asset / Plugin Specific Overrides ---
# Ignore asset log, tracking histories, and local configs
sysinfo.txt
*.apk
*.unitypackage

# --- Firebase & Third-Party Target Architecture Binaries ---
Assets/Firebase/Plugins/**/*.bundle
Assets/Firebase/Plugins/**/*.so
Assets/Firebase/Plugins/**/*.dll
Assets/Resources/Mapbox/MapboxConfiguration.txt

# --- CRITICAL SECURITY: Sensitive API Keys & Config Data ---
# Keeps database secrets and individual configuration strings local
google-services.json
GoogleService-Info.plist

# Android build artifacts cache
.utmp/

# User-specific settings folders
/[Uu]ser[Ss]ettings/